# Copy to backend/.env and edit before running in any non-dev environment.

# JWT signing secret (use `python -c "import secrets; print(secrets.token_hex(32))"`)
JWT_SECRET=change-me-in-prod-please-this-is-only-for-dev
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS - comma-separated list
CORS_ORIGINS=http://localhost:4200,http://127.0.0.1:4200

# Data + vector store paths (defaults are usually fine)
# RBAC_DATA_DIR=../data
# RBAC_CHROMA_DIR=./chroma_store
# RBAC_DB_PATH=./rbac_rag.db
# RBAC_COLLECTION=rbac_rag

# Embedding model (HuggingFace, local, free)
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Ollama LLM
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Chunking
CHUNK_SIZE=800
CHUNK_OVERLAP=100
